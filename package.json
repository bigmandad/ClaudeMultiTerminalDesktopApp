{
  "name": "claude-sessions",
  "version": "0.1.0",
  "description": "Multi-pane terminal manager for Claude CLI sessions",
  "main": "src/main/main.js",
  "scripts": {
    "start": "node build.js && electron .",
    "bundle": "node build.js",
    "postinstall": "node build.js && electron-builder install-app-deps",
    "build": "node build.js && electron-builder --win",
    "build:mac": "node build.js && electron-builder --mac",
    "build:all": "node build.js && electron-builder --win --mac",
    "dev": "node build.js && electron . --dev",
    "setup-turso": "node scripts/setup-turso.js"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@libsql/client": "^0.17.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.9.1",
    "discord.js": "^14.25.1",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.25.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1"
  },
  "author": "Claude Sessions",
  "build": {
    "extends": null
  }
}
